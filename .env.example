# --- PostgreSQL ---
POSTGRES_USER=sreality
POSTGRES_PASSWORD=sreality
POSTGRES_DB=sreality
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Backend ---
# In docker-compose the host is the "postgres" service name; for local (non-docker)
# development against a locally installed Postgres, use "localhost" instead.
DATABASE_URL=postgresql+psycopg2://sreality:sreality@postgres:5432/sreality
REDIS_URL=redis://redis:6379/0

CORS_ORIGINS=["http://localhost:5173"]

# --- Scraping ---
SREALITY_BASE_URL=https://www.sreality.cz
SREALITY_API_BASE=https://www.sreality.cz/api/v1/estates/search
SREALITY_DETAIL_BASE=https://www.sreality.cz/api/v1/estates
SCRAPE_PER_PAGE=999
SCRAPE_CONCURRENCY=8
SCRAPE_REQUEST_DELAY_SECONDS=0.25
SCRAPE_MAX_RETRIES=5
SCRAPE_CONSECUTIVE_FAILURES_BEFORE_FALLBACK=5

# --- Scheduler ---
ENABLE_SCHEDULER=true
INCREMENTAL_SCRAPE_CRON_HOUR=*/6
FULL_SCRAPE_CRON_HOUR=3
ANALYTICS_SNAPSHOT_HOUR=4

# --- API key (guarded endpoints: scrape trigger, recompute, exports) ---
# Backend reads API_KEY; frontend reads VITE_API_KEY. They must match.
API_KEY=dev-local-key

# Frontend (Vercel) — build-time vars for the SPA
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_API_KEY=dev-local-key
# When set on Vercel, proxies /api to this backend (see frontend/vercel.ts).
# Example: https://your-backend.up.railway.app
BACKEND_URL=

# --- Backend (production on Railway / Render) ---
# APP_ENV=production
# API_KEY=<strong-random-secret>
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# CORS_ORIGINS=["https://sreality-platform.vercel.app"]
# ENABLE_SCHEDULER=true
#
# Optional — defaults are fine for most deployments:
# REDIS_URL=redis://...          # reserved for future job locking; not required today
# SREALITY_BASE_URL=https://www.sreality.cz
# SCRAPE_CONCURRENCY=8
# INCREMENTAL_SCRAPE_CRON_HOUR=*/6
# FULL_SCRAPE_CRON_HOUR=3
# ANALYTICS_SNAPSHOT_HOUR=4

# --- Frontend (Vercel) — build-time / deploy-time vars ---
# VITE_API_KEY=<same-as-API_KEY>     # baked into SPA at build; required for exports/scrape triggers
# BACKEND_URL=https://xxx.up.railway.app   # enables /api/* and /health proxy in frontend/vercel.ts
#
# Vercel project settings:
#   Root Directory = frontend
#   Production env: BACKEND_URL, VITE_API_KEY
#   Redeploy after changing BACKEND_URL (rewrites are evaluated at deploy time)
